# Copy to `.env` and fill in. docker-compose picks this up automatically.

# Foundry licensing — either user/pass or a presigned release URL via FOUNDRY_RELEASE_URL.
FOUNDRY_USERNAME=
FOUNDRY_PASSWORD=
FOUNDRY_ADMIN_KEY=change-me

# OIDC client credentials. Issuer URL must end at the realm root for Keycloak,
# e.g. https://keycloak.example.com/realms/foundry
OIDC_CLIENT_SECRET=
